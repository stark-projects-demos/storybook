{
  "name": "stark-storybook-demo",
  "version": "1.0.0",
  "description": "",
  "keywords": [
    "storybook-addons",
    "accessibility",
    "a11y",
    "contrast",
    "wcag"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stark-contrast/storybook"
  },
  "type": "module",
  "license": "MIT",
  "author": "Stark Lab, Inc.",
  "bin": {
    "stark-scan-storybook": "./dist/cli.cjs"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsup",
    "build:watch": "npm run build -- --watch",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "run-p build:watch \"storybook:quiet\" \"watch:tailwind\"",
    "storybook": "nodemon --watch dist --exec \"storybook dev -p 6006 --ci\" & npm run watch:tailwind",
    "storybook:quiet": "nodemon --watch dist --exec \"storybook dev -p 6006 --quiet --ci\"",
    "build-storybook": "storybook build",
    "watch:tailwind": "postcss -w src/styles/global.css -o src/styles/generated.css"
  },
  "devDependencies": {
    "@medv/finder": "^3.2.0",
    "@stark-lab-inc/storybook-addon-stark": "^1.1.1",
    "@storybook/addon-docs": "^9.1.0",
    "@storybook/react-vite": "^9.1.0",
    "@types/node": "^22",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.21",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.8",
    "boxen": "^7.1.1",
    "dotenv": "^16.6.1",
    "esbuild-raw-plugin": "^0.3.1",
    "file-saver": "^2.0.5",
    "markdown-to-jsx": "^7.7.6",
    "nodemon": "^3.1.4",
    "npm-run-all2": "^6.2.3",
    "postcss": "^8.4.31",
    "postcss-cli": "^10.0.0",
    "postcss-import": "^14.1.0",
    "postcss-loader": "^7.0.1",
    "postcss-rem-to-responsive-pixel": "^5.1.3",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "prompts": "^2.4.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.1",
    "storybook": "^9.1.0",
    "tailwind-merge": "^1.14.0",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-motion": "^1.0.1",
    "ts-dedent": "^2.2.0",
    "tsup": "^8.2.4",
    "typescript": "^5.8.2",
    "uuid": "^8.3.2",
    "vite": "^5.3.5",
    "zx": "^8.4.1"
  },
  "peerDependencies": {
    "playwright": "^1.58.2",
    "storybook": "^9.0.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "dependencies": {
    "@playwright/test": "^1.59.1"
  }
}
